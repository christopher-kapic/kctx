enum AuthMethod {
  HTTPS
  SSH
  GITHUB_APP
}

enum CloneStatus {
  PENDING
  CLONING
  READY
  FAILED
}

enum EmbeddingStatus {
  NOT_INDEXED
  INDEXING
  INDEXED
  FAILED
}

model Repository {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  gitProvider String
  orgOrUser   String
  repoName    String
  gitUrl      String
  isPrivate   Boolean     @default(false)
  authMethod  AuthMethod  @default(HTTPS)
  clonedPath  String?
  cloneStatus       CloneStatus     @default(READY)
  embeddingStatus   EmbeddingStatus @default(NOT_INDEXED)
  lastIndexedCommit String?
  embeddingError    String?
  Packages          Package[]

  @@unique([gitProvider, orgOrUser, repoName])
}

model Package {
  id             String     @id @default(cuid())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt
  identifier     String     @unique
  displayName    String
  packageManager String
  defaultTag     String
  kctxHelper     String?
  urls           Json
  repositoryId   String
  Repository     Repository @relation(fields: [repositoryId], references: [id], onDelete: Restrict)

  Conversations Conversation[]

  @@index([repositoryId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @default("New Conversation")
  packageId String
  Package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  ownerId   String
  User      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  shares    ConversationShare[]

  @@index([ownerId])
  @@index([packageId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  role           String
  content        String
  thinking       String?
  conversationId String
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model ConversationShare {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  conversationId String
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sharedWithId   String
  User           User         @relation(fields: [sharedWithId], references: [id], onDelete: Cascade)

  @@unique([conversationId, sharedWithId])
  @@index([sharedWithId])
}

model SiteSettings {
  id                String  @id @default("default")
  sshCloningEnabled Boolean @default(true)
  signupsEnabled    Boolean @default(true)
  opencodeUrl       String  @default("")
  opencodeTimeoutMs Int     @default(30000)
  embeddingBaseUrl  String  @default("")
  embeddingApiKey   String  @default("")
  embeddingModel    String  @default("")
}

model ApiKey {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  name      String
  hashedKey String    @unique
  userId    String
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt DateTime?

  @@index([userId])
}
