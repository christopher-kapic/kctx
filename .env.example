# Required
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-characters

# Optional — override defaults
# DATABASE_URL=file:/data/kctx.db
# PACKAGES_PATH=/packages
# OPENCODE_URL=http://opencode:4096

# Optional — cross-origin deployments only (not needed for Docker single-port setup)
# CORS_ORIGIN=http://localhost:7167
# BETTER_AUTH_URL=http://localhost:7167
